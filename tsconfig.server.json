{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ES2023"],
    "types": ["node"]
  },
  "include": ["src/cli/**/*", "src/server/**/*", "src/shared/**/*"],
  "exclude": ["src/ui/**/*", "node_modules", "dist"]
}
